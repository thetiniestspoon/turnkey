# Frontend (Vite)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Edge Function env vars (set via Supabase dashboard or `supabase secrets set`)
# OPENROUTER_API_KEY=your_openrouter_key
# CENSUS_API_KEY=your_census_api_key (free at api.census.gov)
# FRED_API_KEY=your_fred_api_key (free at fred.stlouisfed.org)
# HUD_API_TOKEN=your_hud_api_token (free at huduser.gov)
